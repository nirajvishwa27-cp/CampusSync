// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
// Updated: Fixed userRole for new users

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return isSignedIn() && exists(userDocPath());
    }

    function userDoc() {
      return get(userDocPath()).data;
    }

    function userRole() {
      return hasUserDoc() ? userDoc().role : null;
    }

    function hasValidRole() {
      return userRole() in ['student', 'faculty', 'admin'];
    }

    function assignedResources() {
      return hasUserDoc() && userDoc().assignedResources is list
        ? userDoc().assignedResources
        : [];
    }

    function canManageResource(resourceId) {
      return isAdmin() || (isFaculty() && resourceId in assignedResources());
    }

    function isStudent()  { return isSignedIn() && hasValidRole() && userRole() == 'student'; }
    function isFaculty()  { return isSignedIn() && hasValidRole() && userRole() == 'faculty'; }
    function isAdmin()    { return isSignedIn() && hasValidRole() && userRole() == 'admin'; }
    function isFacultyOrAdmin() { return isFaculty() || isAdmin(); }

    // Valid status values
    function isValidStatus(status) {
      return status in ['free', 'occupied', 'partial', 'reserved'];
    }

    // ── /users ─────────────────────────────────────────────────
    match /users/{userId} {
      // Any signed-in user can read their own profile
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Allow create on registration (new doc only)
      allow create: if isSignedIn() && request.auth.uid == userId;
      // Only admin can update roles
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /rooms ─────────────────────────────────────────────────
    match /rooms/{roomId} {
      // All signed-in users can read rooms
      allow read: if isSignedIn();

      // Only faculty or admin can update room status fields
      // Must validate: status enum, updatedBy must equal current user
      allow update: if isSignedIn()
        && canManageResource(roomId)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['status', 'updatedAt', 'updatedBy', 'autoResetAt', 'note', 'reservedBy', 'reservedUntil'])
        && request.resource.data.updatedBy == request.auth.uid
        && isValidStatus(request.resource.data.status);

      // Only admin can create / delete rooms
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── /activityLogs ──────────────────────────────────────────────────
    match /activityLogs/{logId} {
      // Faculty/admin can write logs
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && (
          isAdmin()
          || (
            isFaculty()
            && request.resource.data.roomId is string
            && request.resource.data.roomId in assignedResources()
          )
        );
      // Anyone signed in can read logs
      allow read: if isSignedIn();
      allow update, delete: if false;
    }

    // ── /bookings ───────────────────────────────────────────────
    match /bookings/{bookingId} {
      // Students can read their own bookings
      allow read: if isSignedIn()
        && (
          request.auth.uid == resource.data.studentId
          || isAdmin()
          || (
            isFaculty()
            && resource.data.resourceId is string
            && resource.data.resourceId in assignedResources()
          )
        );

      // Students can create booking requests
      allow create: if isSignedIn()
        && isStudent()
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.resourceId is string
        && request.resource.data.startTime is string
        && request.resource.data.endTime is string
        && request.resource.data.startTime < request.resource.data.endTime
        && request.resource.data.respondedBy == null
        && request.resource.data.respondedAt == null
        && request.resource.data.responseNote == '';

      // Faculty can update (approve/decline) for their assigned resources
      // Admin can update any booking
      allow update: if isSignedIn()
        && (
          isAdmin()
          || (
            isFaculty()
            && resource.data.resourceId is string
            && resource.data.resourceId in assignedResources()
          )
        )
        && resource.data.status == 'pending'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'responseNote', 'respondedBy', 'respondedAt'])
        && request.resource.data.status in ['approved', 'declined']
        && request.resource.data.respondedBy == request.auth.uid;

      // Only admin can delete
      allow delete: if isAdmin();
    }

    // ── /chatLogs ───────────────────────────────────────────────
    match /chatLogs/{logId} {
      // Users can read only their own chat logs; admin can read all.
      allow read: if isSignedIn()
        && (
          isAdmin()
          || request.auth.uid == resource.data.uid
        );

      // Chat logs are only written by trusted backend services.
      allow create, update, delete: if false;
    }

    // ── /chatThrottle ───────────────────────────────────────────
    match /chatThrottle/{userId} {
      // Never allow direct client access; this is function-managed.
      allow read, write: if false;
    }
  }
}
